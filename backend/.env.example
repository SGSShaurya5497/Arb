# =============================================================================
# Arb Backend — Environment Variables
# Copy this file to .env for local development (docker-compose uses its own
# environment: block, so .env is only needed if running uvicorn directly).
#
# In Railway: set each var in the service's Variables tab.
# Railway auto-injects DATABASE_URL and REDIS_URL when you attach Postgres/Redis
# add-ons — you can leave those blank until you attach the add-on.
# =============================================================================

# --- PostgreSQL ---
# Railway: provided automatically when you attach a Postgres add-on.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://arb_user:arb_password@localhost:5432/arb

# --- Redis ---
# Railway: provided automatically when you attach a Redis add-on.
# Format: redis://<host>:<port>/<db_number>
REDIS_URL=redis://localhost:6379/0

# --- Celery (uses same Redis as REDIS_URL) ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- JWT ---
# Generate a secure key with: openssl rand -hex 32
# NEVER commit the real value — this signs all auth tokens.
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_run_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS ---
# JSON array of allowed browser origins.
# After deploying frontend to Vercel, add your Vercel URL here.
# Example: CORS_ORIGINS=["http://localhost:5173","https://arb-yourapp.vercel.app"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000"]

# --- Spread Computation ---
SPREAD_WINDOW_SIZE=20
Z_SCORE_ALERT_THRESHOLD=2.0

# --- External APIs ---
# Yahoo Finance (yfinance): no API key required — uses public endpoints.
# MFAPI.in: no API key required — public free API.
# No additional keys needed for current data sources.

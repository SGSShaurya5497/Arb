# =============================================================================
# Arb Frontend — Environment Variables
# Copy this file to .env.local for local development.
# In Vercel: set these in Project Settings → Environment Variables.
#
# Both vars MUST point to your Railway backend URL (from Step 2 of deployment).
# HTTP URL for REST calls, WSS URL for the WebSocket feed.
# =============================================================================

# Base URL of the Railway backend (no trailing slash).
# Example: https://arb-backend-production.up.railway.app
VITE_API_URL=https://your-railway-backend.up.railway.app

# WebSocket base URL of the Railway backend (no trailing slash).
# Use wss:// (secure) for any https:// Railway deployment.
# Example: wss://arb-backend-production.up.railway.app
VITE_WS_URL=wss://your-railway-backend.up.railway.app

# Local dev: leave both vars UNSET (or empty) so Vite's dev proxy handles
# /api, /auth, /ws, and /yf transparently via vite.config.ts.
